# Core server
PORT=5000
NODE_ENV=development

# Database (active runtime)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Supabase (used by server config/auth paths)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI chatbot (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# API/runtime behavior
MAX_FILE_SIZE=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Email (OAuth2 with Gmail)
SMTP_USER=your_email@gmail.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# Subscription UI pricing ids
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_monthly_subscription_id
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_yearly_subscription_id

# Admin/test-only
ADMIN_API_TOKEN=your_admin_api_token

# unused/legacy
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
UPLOAD_PATH=./uploads
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
LOG_FILE=./logs/app.log
OPENAI_API_KEY=your_openai_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
MONGODB_URI=mongodb://localhost:27017/portfolio
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/portfolio
