# 서버 설정
PORT=5000
NODE_ENV=development

# Neon PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# AI Chatbot (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# 파일 업로드 설정
MAX_FILE_SIZE=10485760

# 보안 / Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin API 토큰
# ADMIN_API_TOKEN=your_admin_api_token_here

# 이메일 설정 (OAuth 2.0)
SMTP_USER=your_email@gmail.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Stripe 구독 UI 가격 ID
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxxxxxxxxxx

# 앱 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
